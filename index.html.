<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Y2K Blue Electronics</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
    }

    body{
        overflow:hidden;
        background:
            radial-gradient(circle at top, #163f82 0%, #07111f 35%, #02040a 100%);
        height:100vh;
        font-family:Verdana, sans-serif;
    }

    canvas{
        position:fixed;
        inset:0;
    }

    .noise{
        position:fixed;
        inset:0;
        pointer-events:none;
        opacity:.07;
        mix-blend-mode:screen;
        background-image:
            repeating-radial-gradient(circle at 0 0,
            rgba(255,255,255,.4) 0px,
            transparent 1px,
            transparent 4px);
        animation:noiseMove .2s infinite linear;
    }

    @keyframes noiseMove{
        from{transform:translate(0,0)}
        to{transform:translate(2px,-2px)}
    }

    .glow{
        position:absolute;
        width:800px;
        height:800px;
        border-radius:50%;
        background:radial-gradient(circle,
            rgba(70,180,255,.2),
            transparent 70%);
        filter:blur(60px);
        top:50%;
        left:50%;
        transform:translate(-50%,-50%);
        animation:pulse 6s ease-in-out infinite;
    }

    @keyframes pulse{
        0%,100%{
            transform:translate(-50%,-50%) scale(1);
            opacity:.8;
        }
        50%{
            transform:translate(-50%,-50%) scale(1.15);
            opacity:1;
        }
    }

    .title{
        position:fixed;
        top:30px;
        width:100%;
        text-align:center;
        color:#8ed4ff;
        letter-spacing:8px;
        font-size:14px;
        text-shadow:
            0 0 5px #79d0ff,
            0 0 15px #79d0ff,
            0 0 30px #79d0ff;
        opacity:.8;
        z-index:10;
    }
</style>
</head>

<body>

<div class="glow"></div>
<div class="noise"></div>
<div class="title">✦ incoming call . . . ✦</div>

<canvas id="scene"></canvas>

<script>
const canvas = document.getElementById("scene");
const ctx = canvas.getContext("2d");

let w, h;

function resize(){
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
}
resize();
window.addEventListener("resize", resize);

const particles = [];
const sparkCount = 130;

for(let i=0;i<sparkCount;i++){
    particles.push({
        x:Math.random()*w,
        y:Math.random()*h,
        size:Math.random()*2,
        speedY:Math.random()*0.5 + 0.2,
        opacity:Math.random(),
    });
}

let mouse = {
    x:w/2,
    y:h/2
};

window.addEventListener("mousemove", e=>{
    mouse.x = e.clientX;
    mouse.y = e.clientY;
});

function roundedRect(x,y,width,height,radius){
    ctx.beginPath();
    ctx.moveTo(x+radius,y);
    ctx.lineTo(x+width-radius,y);
    ctx.quadraticCurveTo(x+width,y,x+width,y+radius);
    ctx.lineTo(x+width,y+height-radius);
    ctx.quadraticCurveTo(x+width,y+height,x+width-radius,y+height);
    ctx.lineTo(x+radius,y+height);
    ctx.quadraticCurveTo(x,y+height,x,y+height-radius);
    ctx.lineTo(x,y+radius);
    ctx.quadraticCurveTo(x,y,x+radius,y);
    ctx.closePath();
}

function drawPhone(cx, cy, scale, rotation){
    ctx.save();

    ctx.translate(cx, cy);
    ctx.rotate(rotation);

    ctx.shadowColor = "#57d6ff";
    ctx.shadowBlur = 40;

    // hinge
    ctx.fillStyle = "#78e2ff";
    roundedRect(-18*scale, -10*scale, 36*scale, 20*scale, 10*scale);
    ctx.fill();

    // top
    ctx.fillStyle = "#9be8ff";
    roundedRect(-80*scale, -210*scale, 160*scale, 180*scale, 22*scale);
    ctx.fill();

    // bottom
    roundedRect(-90*scale, 20*scale, 180*scale, 220*scale, 22*scale);
    ctx.fill();

    // screen
    ctx.fillStyle = "#7ed6ff";
    ctx.shadowBlur = 25;
    roundedRect(-45*scale, -175*scale, 90*scale, 70*scale, 12*scale);
    ctx.fill();

    // glowing screen
    const grad = ctx.createLinearGradient(0,-175*scale,0,-105*scale);
    grad.addColorStop(0,"#d9ffff");
    grad.addColorStop(1,"#7dd8ff");

    ctx.fillStyle = grad;
    roundedRect(-40*scale, -170*scale, 80*scale, 60*scale, 10*scale);
    ctx.fill();

    // keypad
    ctx.shadowBlur = 12;

    for(let row=0; row<4; row++){
        for(let col=0; col<3; col++){
            let x = -45*scale + col*40*scale;
            let y = 70*scale + row*35*scale;

            ctx.beginPath();
            ctx.arc(x, y, 12*scale, 0, Math.PI*2);

            const buttonGrad = ctx.createRadialGradient(
                x,y,1,
                x,y,14*scale
            );

            buttonGrad.addColorStop(0, "#d6ffff");
            buttonGrad.addColorStop(1, "#4ab7ff");

            ctx.fillStyle = buttonGrad;
            ctx.fill();
        }
    }

    // antenna spark
    ctx.strokeStyle = "#c8f7ff";
    ctx.lineWidth = 3*scale;
    ctx.beginPath();
    ctx.moveTo(0,-210*scale);
    ctx.quadraticCurveTo(
        40*scale,
        -260*scale,
        70*scale,
        -230*scale
    );
    ctx.stroke();

    ctx.restore();
}

function drawStarPhone(cx, cy, scale, rotation){
    ctx.save();

    ctx.translate(cx, cy);
    ctx.rotate(rotation);

    ctx.shadowColor = "#7be8ff";
    ctx.shadowBlur = 45;

    ctx.fillStyle = "#b5f4ff";

    ctx.beginPath();

    for(let i=0;i<5;i++){
        ctx.lineTo(
            Math.cos((18+i*72)/180*Math.PI)*120*scale,
            -Math.sin((18+i*72)/180*Math.PI)*120*scale
        );
        ctx.lineTo(
            Math.cos((54+i*72)/180*Math.PI)*50*scale,
            -Math.sin((54+i*72)/180*Math.PI)*50*scale
        );
    }

    ctx.closePath();
    ctx.fill();

    // screen
    ctx.fillStyle="#68d4ff";
    ctx.beginPath();
    ctx.arc(0,-20*scale,40*scale,0,Math.PI*2);
    ctx.fill();

    // buttons
    for(let i=0;i<6;i++){
        ctx.beginPath();
        ctx.arc(
            -35*scale + (i%3)*35*scale,
            40*scale + Math.floor(i/3)*35*scale,
            10*scale,
            0,
            Math.PI*2
        );
        ctx.fillStyle="#d8ffff";
        ctx.fill();
    }

    ctx.restore();
}

function animate(){
    ctx.clearRect(0,0,w,h);

    // floating particles
    particles.forEach(p=>{
        p.y -= p.speedY;

        if(p.y < -10){
            p.y = h + 10;
            p.x = Math.random()*w;
        }

        ctx.beginPath();
        ctx.fillStyle = `rgba(130,220,255,${p.opacity})`;
        ctx.arc(p.x,p.y,p.size,0,Math.PI*2);
        ctx.fill();
    });

    // glow trail
    ctx.beginPath();
    const glow = ctx.createRadialGradient(
        mouse.x,
        mouse.y,
        0,
        mouse.x,
        mouse.y,
        180
    );

    glow.addColorStop(0,"rgba(120,220,255,.15)");
    glow.addColorStop(1,"rgba(120,220,255,0)");

    ctx.fillStyle = glow;
    ctx.arc(mouse.x,mouse.y,180,0,Math.PI*2);
    ctx.fill();

    // floating phones
    const t = Date.now() * 0.001;

    drawPhone(
        w*0.35 + Math.sin(t)*30,
        h*0.5 + Math.cos(t*1.2)*20,
        1,
        Math.sin(t)*0.15
    );

    drawStarPhone(
        w*0.72 + Math.cos(t*0.8)*25,
        h*0.42 + Math.sin(t)*20,
        .9,
        Math.cos(t)*0.2
    );

    requestAnimationFrame(animate);
}

animate();
</script>

</body>
</html>
